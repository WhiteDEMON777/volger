---
import { cn } from '../../utils/classNames';

export interface Props {
  variant?: 'primary' | 'secondary' | 'link' | 'icon' | 'icon-small' | 'round' | 'outline';
  color?: 'white' | 'blue' | 'red' | 'black' | 'default' | 'grey';
  size?: 'small' | 'medium' | 'large';
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  close?: boolean;
  block?: boolean;
  iconLeft?: string;
  iconRight?: string;
  class?: string;
  ariaLabel?: string;
  [key: string]: any; // Поддержка дополнительных атрибутов
}

const {
  variant = 'primary',
  color = 'white',
  size = 'medium',
  type = 'button',
  disabled = false,
  block = false,
  close,
  iconLeft,
  iconRight,
  class: className = '',
  ariaLabel,
  ...rest
} = Astro.props;

const buttonClasses = cn(
  'btn',
  variant !== 'primary' && `btn--${variant}`,
  color !== 'white' && `btn--${color}`,
  size !== 'medium' && `btn--${size}`,
  block && 'btn--block',
  disabled && 'btn--disabled',
  variant === 'icon-small' && 'btn--round btn--icon-small',
  className
);
---

<button
  type={type}
  disabled={disabled}
  aria-label={ariaLabel}
  data-close-modal={close}
  class={buttonClasses}
  {...rest}
>
  {iconLeft && <span class={`btn__icon-left icon-${iconLeft}`}></span>}
  <slot />
  {iconRight && <span class={`btn__icon-right icon-${iconRight}`}></span>}
</button>
