
---
export type AccordionType = { title: string; text: string }[];

interface Props {
    items: AccordionType;
}

const {
    items
} = Astro.props;
---

<div class="accordion">
    {
        items.map(({title, text}) => (
                <div class="ac accordion__container">
                    <div class="ac-header">
                        <div class="ac-trigger accordion__btn">
                            <div class="accordion__title">{title}</div>
                            <div class="accordion__icon icon-arrow"></div>
                        </div>
                    </div>
                    <div class="ac-panel">
                        <div class="accordion__content">
                            {text}
                        </div>
                    </div>
                </div>
        ))
    }
</div>


